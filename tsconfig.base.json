{
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "lib": ["esnext", "webworker"],
    "allowJs": true,
    "strict": true,
    "moduleResolution": "bundler",
    "types": ["node", "screeps"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
